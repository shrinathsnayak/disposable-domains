{
  "name": "disposable-domains",
  "version": "1.0.0",
  "description": "Aggregator for disposable email domain lists",
  "author": "Shrinath Nayak",
  "license": "MIT",
  "keywords": [
    "disposable-email",
    "blocklist",
    "spam",
    "email-validation",
    "throwaway-email"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "generate": "tsx src/generate.ts",
    "generate:prod": "tsc && node dist/generate.js",
    "test": "tsx --test test/utils.test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix",
      "eslint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
